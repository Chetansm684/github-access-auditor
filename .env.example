# Required: GitHub Personal Access Token
# Create at https://github.com/settings/tokens
# Required scopes: read:org, repo
GITHUB_TOKEN=ghp_your_token_here

# Optional: Server port (default: 3000)
PORT=3000

# Optional: Default organization name
# Can be overridden via ?org= query parameter
DEFAULT_ORG=

# Optional: Max concurrent API requests to GitHub (default: 10)
# Keep below 100 to avoid secondary rate limits
MAX_CONCURRENCY=10
